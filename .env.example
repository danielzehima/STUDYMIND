# Copier ce fichier en .env.local et renseigner les vraies valeurs.
# Ne jamais committer .env.local (il est dans .gitignore).

# Supabase — Project Settings > API sur le dashboard du projet
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret — ne jamais exposer au frontend, utilisé uniquement dans lib/supabase/admin.ts
SUPABASE_SERVICE_ROLE_KEY=

# DeepSeek — https://platform.deepseek.com/api_keys
# Attention : deepseek-chat/deepseek-reasoner sont dépréciés le 24/07/2026,
# utiliser les nouveaux identifiants de modèle (deepseek-v4-flash ou équivalent).
DEEPSEEK_API_KEY=

# GeniusPay (mobile money / carte) — https://geniuspay.ci/docs/api
# Dashboard GeniusPay > Paramètres > API pour les clés, > Webhooks pour le
# secret whsec_... (créer un webhook pointant vers
# https://<domaine>/api/webhooks/payment avec l'événement payment.success
# au minimum).
GENIUSPAY_API_KEY=
GENIUSPAY_API_SECRET=
GENIUSPAY_WEBHOOK_SECRET=
